PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/hotelbooking
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
